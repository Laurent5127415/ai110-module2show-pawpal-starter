classDiagram
    class Owner {
        -name: str
        -contact_info: str
        +add_pet(pet: Pet) void
        +get_all_pets() list[Pet]
    }
    
    class Pet {
        -name: str
        -species: str
        -age: int
        -owner: Owner
        +add_task(task: Task) void
        +get_tasks() list[Task]
    }
    
    class Task {
        -name: str
        -duration: float
        -priority: str
        -scheduled_time: datetime
        -task_type: str
        +is_complete() bool
        +mark_done() void
    }
    
    class Scheduler {
        -tasks: list[Task]
        -constraints: dict
        +generate_schedule() list[Task]
        +sort_by_priority() list[Task]
        +detect_conflicts() list
    }
    
    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler --> "*" Task : manages
